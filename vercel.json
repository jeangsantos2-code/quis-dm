{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/quiz/index.html" },
    { "source": "/quiz", "destination": "/quiz/index.html" }
  ],
  "headers": [
    {
      "source": "/quiz/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
